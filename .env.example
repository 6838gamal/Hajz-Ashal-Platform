# Copy to .env for local (non-Replit) runs. On Replit, DATABASE_URL and the
# PG* vars are already injected by the built-in PostgreSQL database.

ENVIRONMENT=development

# EXTERNAL_DATABASE_URL takes priority over DATABASE_URL when set - use it to
# point the app at an external Postgres instance (e.g. Render) instead of
# Replit's built-in database. Store it via Replit Secrets, never in this file.
# EXTERNAL_DATABASE_URL=postgresql://user:pass@host/dbname
DATABASE_URL=postgresql://app:password@localhost:5432/app

# Secret used to sign JWTs. On Replit this is provided via the SESSION_SECRET
# secret automatically if JWT_SECRET itself is not set.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

CORS_ORIGINS=*
LOG_LEVEL=info
